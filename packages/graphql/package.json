{
  "name": "@repo/graphql",
  "version": "1.0.0",
  "description": "Shared GraphQL client, queries, and providers for HelloFi",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit"
  },
  "keywords": [
    "graphql",
    "apollo"
  ],
  "author": "HelloFi Team",
  "license": "ISC",
  "dependencies": {
    "@apollo/client": "*",
    "apollo-upload-client": "*",
    "extract-files": "^13.0.0",
    "graphql-tag": "*",
    "sonner": "*"
  },
  "peerDependencies": {
    "react": "*"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/react": "*",
    "typescript": "^5.3.0"
  }
}
