// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  ACTIVE
  INACTIVE
}

enum UserType {
  SUPERADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InventoryStatus {
  NOT_LISTED
  LISTED
  SOLD
}

enum PaymentMode {
  CASH
  UPI
  CREDIT_CARD
  DEBIT_CARD
  SPLIT_PAYMENT
  RAZORPAY
}

enum BuyingCondition {
  UNBOXED
  SUPERB
  GOOD
  FAIR
  PARTIALLY_FAIR
}

enum BuyingAvailability {
  IN_STOCK
  OUT_OF_STOCK
}

enum BuyingOS {
  WINDOWS
  MACOS
}

enum WarrantyType {
  HELLOFI_WARRANTY
  BRAND_WARRANTY
  NO_WARRANTY
}

enum SaleType {
  DIRECT
  EXCHANGE
}

enum InvoiceWarrantyType {
  BRAND
  HELLOFI
  NONE
}

enum InvoiceStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

model User {
  id       String     @id @default(cuid())
  fName    String
  lName    String
  contact  String     @unique
  password String?
  email    String?    @unique
  userType UserType   @default(USER)
  status   UserStatus @default(ACTIVE)

  emailVerified   Boolean @default(false)
  contactVerified Boolean @default(false)

  dailyOtpAttempts Int       @default(0)
  lastOtpDate      DateTime?
  isOtpBlocked     Boolean   @default(false)
  pincode          String

  dailyResendOtpAttempts Int       @default(0)
  lastResendDate         DateTime?
  isResendBlocked        Boolean   @default(false)

  dailyVerificationOtpAttempts Int       @default(0)
  lastVerificationDate         DateTime?
  isVerificationBlocked        Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]

  @@index([email])
  @@index([contact])
  @@map("users")
}

model Session {
  id                  String   @id @default(cuid())
  sessionToken        String   @unique
  refreshToken        String?  @unique
  userId              String
  expires             DateTime
  sessionTokenExpires DateTime

  deviceId   String?
  deviceInfo String?
  ipAddress  String?

  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@index([refreshToken])
  @@map("sessions")
}

model Banner {
  id          String    @id @default(uuid())
  alt         String
  lg          String
  sm          String
  redirectUrl String?
  priority    Int       @default(0)
  isActive    Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id           String   @id @default(uuid())
  name         String
  seoName      String   @unique
  categoryType String
  image        String
  priority     Int
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  buyingProducts    BuyingProduct[]
  brandCategories   BrandCategory[]
  inventoryProducts InventoryProduct[]
  series            Series[]
  sellingProducts   SellingProduct[]
}

model Brand {
  id        String   @id @default(uuid())
  name      String
  seoName   String   @unique
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyingProducts    BuyingProduct[]
  brandCategories   BrandCategory[]
  inventoryProducts InventoryProduct[]
  series            Series[]
  sellingProducts   SellingProduct[]
}

model BrandCategory {
  id         String   @id @default(uuid())
  brandId    String
  categoryId String
  status     Status   @default(ACTIVE)
  priority   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([brandId, categoryId])
}

model BuyingProduct {
  id              String   @id @default(uuid())
  productName     String
  productSubtitle String
  slug            String   @unique
  brandId         String
  categoryId      String
  isTrending      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  brand          Brand                 @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category       Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants       BuyingVariant[]
  images         BuyingProductImage[]
  specifications BuyingSpecification[]
}

model BuyingVariant {
  id                  String             @id @default(uuid())
  productId           String
  sku                 String
  shortId             String             @unique
  liveLink            String?
  variantSubtitle     String?
  color               String?
  colorCode           String?
  storage             String
  ram                 String?
  price               Decimal
  mrp                 Decimal
  emiBasePrice        Decimal?
  quantity            Int
  reservedQuantity    Int                @default(0)
  productSpec         String?
  condition           BuyingCondition
  availability        BuyingAvailability @default(IN_STOCK)
  screenSize          String?
  os                  BuyingOS?
  processor           String?
  batteryCapacity     String?
  warrantyType        WarrantyType
  warrantyDescription String?
  whatsInTheBox       String[]
  whatsExtra          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  product BuyingProduct        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images  BuyingProductImage[]

  @@index([shortId])
}

model BuyingProductImage {
  id        String   @id @default(uuid())
  variantId String?
  productId String?
  xs        String?
  sm        String?
  md        String?
  lg        String?
  alt       String?
  priority  Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant BuyingVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  product BuyingProduct? @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model BuyingSpecification {
  id        String   @id @default(uuid())
  productId String
  key       String
  value     String
  group     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product BuyingProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model InventoryProduct {
  id           String @id @default(uuid())
  imeiOrSerial String
  orderId      String

  purchaseDate        DateTime
  productName         String
  ram                 String?
  storage             String?
  costPrice           Decimal
  otherCharges        Decimal  @default(0)
  sellingOtherCharges Decimal  @default(0)

  brandId    String
  categoryId String

  customerName    String
  customerEmail   String?
  customerPhone   String
  customerAddress String

  status InventoryStatus @default(NOT_LISTED)

  sellingDate  DateTime?
  sellingPrice Decimal?
  invoice      String?

  sellingCustomerName    String?
  sellingCustomerEmail   String?
  sellingCustomerPhone   String?
  sellingCustomerAddress String?

  paymentMode         PaymentMode?
  receivedInBank      Decimal?
  splitPaymentDetails String?

  tat         Int?
  grossProfit Decimal?

  screenCondition String  @default("NO")
  bodyCondition   String  @default("NO")
  deviceIssues    String?

  hasBox          Boolean @default(false)
  hasCharger      Boolean @default(false)
  hasOriginalBill Boolean @default(false)

  warrantyType         String    @default("ABOVE_1_YEAR")
  warrantyPurchaseDate DateTime?

  isActive Boolean @default(true)
  notes    String?

  // ── Exchange chain fields ──
  isExchangeItem Boolean  @default(false)
  exchangeValue  Decimal? // ← value credited to customer for this device

  // ── Direct parent — the sold device this was exchanged against ──
  parentInventoryId String?
  parentInventory   InventoryProduct?  @relation("ExchangeChain", fields: [parentInventoryId], references: [id])
  exchangedItems    InventoryProduct[] @relation("ExchangeChain")

  // ── Root of the chain — same for ALL nodes, enables flat fetch of entire chain ──
  rootInventoryId String?
  rootInventory   InventoryProduct?  @relation("ExchangeRoot", fields: [rootInventoryId], references: [id])
  chainMembers    InventoryProduct[] @relation("ExchangeRoot")

  // ── Which invoice brought this device in via exchange ──
  sourceInvoiceId String?
  sourceInvoice   Invoice? @relation("ExchangeInventory", fields: [sourceInvoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand    Brand    @relation(fields: [brandId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  invoiceItem InvoiceItem?

  @@index([imeiOrSerial])
  @@index([customerEmail])
  @@index([customerPhone])
  @@index([sellingCustomerEmail])
  @@index([sellingCustomerPhone])
  @@index([purchaseDate])
  @@index([sellingDate])
  @@index([status])
  @@index([parentInventoryId])
  @@index([rootInventoryId])
  @@index([sourceInvoiceId])
  @@map("inventory_products")
}

model InvoiceCompanySettings {
  id        String  @id @default(cuid())
  label     String
  isDefault Boolean @default(false)

  name     String
  address  String
  contact  String
  email    String
  gstin    String
  logoUrl  String?
  stampUrl String?

  defaultInvoiceTermsBrand   String @db.Text
  defaultInvoiceTermsHellofi String @db.Text
  defaultInvoiceTermsNone    String @db.Text
  defaultBankDetails         String @db.Text

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@map("invoice_company_settings")
}

model InvoiceCounter {
  id            String   @id @default(cuid())
  financialYear String
  lastNumber    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([financialYear])
  @@map("invoice_counters")
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  invoiceDate   DateTime

  companySettingsId String
  companySettings   InvoiceCompanySettings @relation(fields: [companySettingsId], references: [id])

  clientName          String
  clientAddress       String
  clientEmail         String
  clientContact       String
  clientGstin         String?
  isInsideBangalore   Boolean      @default(true)
  paidBy              PaymentMode?
  splitPaymentDetails String?

  saleType SaleType @default(DIRECT)

  warrantyType   InvoiceWarrantyType @default(BRAND)
  warrantyMonths Int?

  grossValue    Float
  taxAmount     Float
  totalAmount   Float
  exchangeValue Float @default(0)
  amountPaid    Float

  cgst Float @default(0)
  sgst Float @default(0)
  igst Float @default(0)

  customInvoiceTerms String? @db.Text
  customBankDetails  String? @db.Text

  pdfUrl String?

  status InvoiceStatus @default(DRAFT)

  items              InvoiceItem[]
  exchangeItems      InvoiceExchangeItem[]
  exchangedInventory InventoryProduct[]    @relation("ExchangeInventory")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceNumber])
  @@index([clientEmail])
  @@index([clientContact])
  @@index([invoiceDate])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  inventoryProductId String?           @unique
  inventoryProduct   InventoryProduct? @relation(fields: [inventoryProductId], references: [id])

  product      String
  serialNumber String?
  hsnSac       String?

  qty      Int
  uom      String
  rate     Float
  total    Float
  discount Float  @default(0)
  gross    Float

  gstAmount   Float @default(0)
  cgstPercent Float @default(0)
  cgstAmount  Float @default(0)
  sgstPercent Float @default(0)
  sgstAmount  Float @default(0)
  igstPercent Float @default(0)
  igstAmount  Float @default(0)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([inventoryProductId])
  @@map("invoice_items")
}

model InvoiceExchangeItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productName   String
  serialNumber  String?
  brandId       String?
  categoryId    String?
  ram           String?
  storage       String?
  exchangeValue Float   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@map("invoice_exchange_items")
}

model Series {
  id         String   @id @default(cuid())
  brandId    String
  categoryId String
  seriesName String
  status     Status   @default(ACTIVE)
  priority   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  brand           Brand            @relation(fields: [brandId], references: [id])
  category        Category         @relation(fields: [categoryId], references: [id])
  sellingProducts SellingProduct[]

  @@map("series")
}

model SellingProduct {
  id             String    @id @default(cuid())
  productName    String
  productSeoName String    @unique
  brandId        String
  categoryId     String
  seriesId       String
  image          String
  releasedYear   Int?
  launchedDate   DateTime?
  productPrice   Float?
  status         Status    @default(ACTIVE)
  hasVariants    Boolean   @default(false)
  isConstantRam  Boolean   @default(false)
  ram            String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  brand    Brand            @relation(fields: [brandId], references: [id])
  category Category         @relation(fields: [categoryId], references: [id])
  series   Series           @relation(fields: [seriesId], references: [id])
  variants SellingVariant[]

  @@map("selling_products")
}

model SellingVariant {
  id               String   @id @default(cuid())
  sellingProductId String
  ram              String?
  storage          String
  productPrice     Float
  status           Status   @default(ACTIVE)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sellingProduct SellingProduct @relation(fields: [sellingProductId], references: [id], onDelete: Cascade)

  @@map("selling_variants")
}
